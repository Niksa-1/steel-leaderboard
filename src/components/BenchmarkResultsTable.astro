---
import type { BenchmarkResultRow, BenchmarkScope } from "../lib/benchmark-hub";
import { benchmarkScopeLabels } from "../lib/benchmark-hub";

interface Props {
  rows: BenchmarkResultRow[];
  scope: BenchmarkScope;
  heading?: string;
  slug?: string;
}

const { rows, scope, heading = "Leaderboard", slug = "" } = Astro.props;
---

<section class="table-shell w-full">
  <div class="lb-module-head flex items-center justify-between gap-3 px-4 py-3">
    <h2 class="m-0 text-sm font-semibold text-[var(--color-text-strong)]">{heading}</h2>
    <span class="badge">{benchmarkScopeLabels[scope]} scope</span>
  </div>
  <div class="overflow-x-auto">
    <table class="min-w-[980px] w-full border-collapse text-sm">
      <thead class="lb-header text-left text-xs uppercase tracking-[0.04em] text-[var(--color-text-muted)]">
        <tr>
          <th class="px-3 py-2 font-semibold">Rank</th>
          <th class="px-3 py-2 font-semibold">System / Submission</th>
          <th class="px-3 py-2 font-semibold">Score</th>
          <th class="px-3 py-2 font-semibold">Organization</th>
          <th class="px-3 py-2 font-semibold">Notes</th>
          <th class="px-3 py-2 font-semibold">Source</th>
          <th class="px-3 py-2 font-semibold text-center">Share</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr class="lb-row group align-middle">
            <td class="px-3 py-3 font-semibold">{row.rank}</td>
            <td class="px-3 py-3 text-[var(--color-text-strong)]">
              <div class="flex flex-wrap items-center gap-2">
                <span>{row.systemName}</span>
                {row.isNew && <span class="badge badge-accent">New</span>}
              </div>
            </td>
            <td class="px-3 py-3 font-semibold">{row.scoreDisplay}</td>
            <td class="px-3 py-3">{row.organization}</td>
            <td class="px-3 py-3 muted">{row.notesShort}</td>
            <td class="px-3 py-3">
              <a href={row.sourceUrl} target="_blank" rel="noopener noreferrer nofollow">
                Source
              </a>
            </td>
            <td class="px-3 py-3">
              <button
                class="copy-badge-btn muted cursor-pointer select-none text-xs whitespace-nowrap"
                data-url={`https://leaderboard.steel.dev/og/${slug}/${row.rank}.png`}
              >
                Share
              </button>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
<div class="flex justify-end mb-2">
  <button
    class="copy-md-btn badge cursor-pointer select-none"
    data-rows={JSON.stringify(rows)}
    data-heading={heading}
  >
    copy as markdown
  </button>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-md-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const rows = JSON.parse(btn.dataset.rows ?? "[]") as {
        rank: number;
        systemName: string;
        organization: string;
        scoreDisplay: string;
        notesShort: string;
        sourceUrl: string;
      }[];
      const heading = btn.dataset.heading ?? "Leaderboard";

      const header = `| Rank | System | Organization | Score | Notes |`;
      const divider = `| --- | --- | --- | --- | --- |`;
      const rowLines = rows.map(
        (r) =>
          `| #${r.rank} | [${r.systemName}](${r.sourceUrl}) | ${r.organization} | ${r.scoreDisplay} | ${r.notesShort} |`
      );

      const md = [`## ${heading}`, ``, header, divider, ...rowLines].join("\n");

      navigator.clipboard.writeText(md).then(() => {
        const original = btn.textContent;
        btn.textContent = "copied!";
        setTimeout(() => (btn.textContent = original), 1800);
      });
    });
  });
</script>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-badge-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      navigator.clipboard.writeText(btn.dataset.url ?? "").then(() => {
        const orig = btn.textContent;
        btn.textContent = "copied!";
        setTimeout(() => (btn.textContent = orig), 1800);
      });
    });
  });
</script>